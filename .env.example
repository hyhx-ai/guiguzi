# ─── NovaClaw Environment Configuration ───
# Copy this file to .env and fill in your values

# ─── AI Provider API Keys ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Ollama (Local AI) ───
OLLAMA_BASE_URL=http://localhost:11434

# ─── Gateway ───
GATEWAY_PORT=18789
GATEWAY_HOST=0.0.0.0

# ─── Web Console ───
WEB_PORT=3000
WEB_HOST=0.0.0.0

# ─── Channel Webhooks (optional) ───
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# ─── Storage ───
DATA_DIR=/var/lib/novaclaw
LOG_DIR=/var/log/novaclaw
