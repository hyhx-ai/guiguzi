# Guiguzi Gateway Environment Configuration
# Copy to /etc/guiguzi/env and fill in your values

# ─── AI Providers ───
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1     # Or Azure/Qwen endpoint
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Ollama (local, no key needed) ───
OLLAMA_BASE_URL=http://localhost:11434

# ─── Gateway ───
GATEWAY_PORT=18789
GATEWAY_HOST=0.0.0.0

# ─── Channel Webhooks (optional) ───
# FEISHU_APP_ID=...
# FEISHU_APP_SECRET=...
# SLACK_SIGNING_SECRET=...
# SLACK_BOT_TOKEN=xoxb-...
# DISCORD_BOT_TOKEN=...

# ─── Budget ───
DAILY_BUDGET_USD=10
MAX_COST_PER_MTOKEN=5
