{
  "name": "@guiguzi/ai",
  "version": "0.1.0-alpha",
  "description": "Guiguzi AI provider abstraction layer - unified interface for 20+ LLM providers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "eventsource-parser": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "files": ["dist"],
  "license": "MIT"
}
