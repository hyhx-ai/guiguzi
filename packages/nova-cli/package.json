{
  "name": "@guiguzi/cli",
  "version": "0.1.0-alpha",
  "description": "Guiguzi Terminal Coding Agent - the main CLI entry point",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "guiguzi": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@guiguzi/ai": "workspace:*",
    "@guiguzi/router": "workspace:*",
    "@guiguzi/agent-core": "workspace:*",
    "@guiguzi/tui": "workspace:*",
    "@guiguzi/web": "workspace:*",
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
