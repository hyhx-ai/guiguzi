{
  "name": "@novaclaw/cli",
  "version": "0.1.0-alpha",
  "description": "NovaClaw Terminal Coding Agent - the main CLI entry point",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nova": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@novaclaw/ai": "workspace:*",
    "@novaclaw/router": "workspace:*",
    "@novaclaw/agent-core": "workspace:*",
    "@novaclaw/tui": "workspace:*",
    "commander": "^13.0.0",
    "ink": "^5.1.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
