{
  "name": "@novaclaw/gateway",
  "version": "0.1.0-alpha",
  "description": "NovaClaw Multi-Channel Gateway - Feishu, Slack, Discord, Web adapter",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@novaclaw/ai": "workspace:*",
    "@novaclaw/router": "workspace:*",
    "@novaclaw/agent-core": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
