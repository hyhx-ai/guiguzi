{
  "name": "@guiguzi/web",
  "version": "0.1.0-alpha",
  "description": "Guiguzi Web Management Console",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@guiguzi/agent-core": "workspace:*",
    "@guiguzi/router": "workspace:*",
    "@hono/node-server": "^2.0.8",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist", "src/console.html"],
  "license": "MIT"
}
